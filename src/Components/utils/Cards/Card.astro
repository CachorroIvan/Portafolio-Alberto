---
interface Props {
  title?: string;
  class?: string;
}
const { title, class: className } = Astro.props;
---
<div class:list={[
  "bg-slate-900/40 backdrop-blur-md border border-yellow-500/30 rounded-2xl p-6",
  "shadow-[0_0_20px_rgba(0,0,0,0.3)] hover:border-yellow-500/60 transition-colors",
  className
]}>
  {title && <h3 class="text-yellow-500 text-xl font-bold mb-4">{title}</h3>}
  <slot />
</div>