---
import Card from "./utils/Cards/Card.astro";
---
<section id="contact" class="my-16">
    <h2 class="text-3xl font-bold text-white mb-8 border-b border-white/10 pb-4">Contact Me</h2>
    <Card class="max-w-2xl mx-auto">
        <form class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-medium text-gray-400 mb-2">Name</label>
                    <input type="text" class="w-full bg-[#030712]/50 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-yellow-500 transition-colors" placeholder="Your name" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-400 mb-2">Email</label>
                    <input type="email" class="w-full bg-[#030712]/50 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-yellow-500 transition-colors" placeholder="your@email.com" />
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-400 mb-2">Message</label>
                <textarea rows="4" class="w-full bg-[#030712]/50 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-yellow-500 transition-colors" placeholder="How can I help you?"></textarea>
            </div>
            <button type="button" class="w-full bg-linear-to-r from-yellow-600 to-yellow-500 text-white font-medium py-3 rounded-lg hover:shadow-[0_0_15px_rgba(245,158,11,0.5)] transition-all">
                Send Message
            </button>
        </form>
    </Card>
</section>