---
import '../assets/css/base.css';
import Header from '../Components/Header.astro';
import Contact from '../Components/Contact.astro';
import Hero from "../Components/Hero.astro";
import Card from '../Components/utils/Cards/Card.astro';

const currentTechs = [
  { name: "C++", icon: "/icons/c++.png" },
  { name: "SQL", icon: "/icons/sql.png" },
  { name: "Fritzing", icon: "/icons/fritzing.png" },
  { name: "Office", icon: "/icons/office.png" }
];

const learningTechs = [
  { name: "Java", icon: "/icons/java.png" },
  { name: "Python", icon: "/icons/python.png" },
  { name: "Android Studio", icon: "/icons/android.png" },
  { name: "Kotlin", icon: "/icons/kotlin.png" },
  { name: "Linux", icon: "/icons/linux.png" },
  { name: "AWS Cloud", icon: "/icons/aws.png" },
  { name: "Vue.js", icon: "/icons/vue.png" },
  { name: "Astro", icon: "/icons/astro.png" },
  { name: "Javascript", icon: "/icons/javascript.png" },
  { name: "Css", icon: "/icons/css.png" }
];
---

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Jose Alberto | Portfolio</title>
</head>
<body class="text-gray-300 font-sans antialiased selection:bg-yellow-500/30">
    
    <canvas id="network-canvas"></canvas>

    <Header />

    <main class="container mx-auto px-6 pt-32 pb-20 relative z-10 max-w-6xl space-y-24">
        
        <section id="about" class="grid grid-cols-1 md:grid-cols-3 gap-10 items-center">
            <div class="relative group mx-auto md:mx-0 w-full max-w-xs">
                <div class="absolute -inset-1 bg-linear-to-r from-yellow-500 to-blue-500 rounded-2xl blur opacity-30 group-hover:opacity-60 transition duration-1000"></div>
                <div class="relative aspect-3/4 bg-slate-800 rounded-2xl overflow-hidden border border-white/10 flex items-center justify-center">
                    <img src="src/img/Alberto.jpeg" alt="Jose Alberto" class="w-full h-full object-cover" /> 
                </div>
            </div>

            <Card class="md:col-span-2">
                <h1 class="text-4xl md:text-5xl font-bold text-white mb-2">Jose Alberto De Leon Morales</h1>
                <p class="text-xl text-yellow-500 mb-6 font-medium">Computer Engineering Graduate | Aspiring Cloud & IoT Developer</p>
                
                <div class="space-y-4 text-gray-300 leading-relaxed font-light">
                    <p>
                        Computer Engineering graduate from <span class="text-cyan-400 font-medium">ESIME Culhuacán</span> with foundational knowledge in <span class="text-emerald-400 font-medium">programming, circuit design, and networking</span>.
                    </p>
                    <p>
                        Participated in the development of an <span class="text-yellow-400 font-medium">assistive technology project</span> for people with hearing disabilities, contributing to the electronic circuit and schematic design of a smartwatch prototype that detects emergency sounds and provides visual and vibration alerts.
                    </p>
                    <p>
                        Currently seeking an entry-level position in <span class="text-cyan-400 font-medium">software development, cloud computing, or IoT</span>, where I can apply my technical skills and continue growing as a professional in the technology field.
                    </p>
                </div>
                
                <div class="mt-8">
                    <a href="#contact" class="inline-block px-8 py-3 bg-white/5 border border-yellow-500/50 rounded-lg text-yellow-500 hover:bg-yellow-500/10 transition-colors">Contact Me</a>
                </div>
            </Card>
        </section>

        <section id="services">
            <h2 class="text-3xl font-bold text-white mb-8 border-b border-white/10 pb-4">Services</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <Card class="hover:-translate-y-2 transition-transform text-center group">
                    <div class="text-4xl mb-4 group-hover:scale-110 transition-transform">🤖</div>
                    <h3 class="text-lg font-bold text-white mb-2">Embedded & IoT</h3>
                    <p class="text-sm text-gray-400">Development of embedded systems and IoT prototypes using C++.</p>
                </Card>
                <Card class="hover:-translate-y-2 transition-transform text-center group">
                    <div class="text-4xl mb-4 group-hover:scale-110 transition-transform">🗄️</div>
                    <h3 class="text-lg font-bold text-white mb-2">Database Mgmt</h3>
                    <p class="text-sm text-gray-400">Design, administration, and query optimization using SQL.</p>
                </Card>
                <Card class="hover:-translate-y-2 transition-transform text-center group">
                    <div class="text-4xl mb-4 group-hover:scale-110 transition-transform">⚡</div>
                    <h3 class="text-lg font-bold text-white mb-2">Circuit Design</h3>
                    <p class="text-sm text-gray-400">Electronic schematic and PCB design using Fritzing.</p>
                </Card>
                <Card class="hover:-translate-y-2 transition-transform text-center group">
                    <div class="text-4xl mb-4 group-hover:scale-110 transition-transform">📄</div>
                    <h3 class="text-lg font-bold text-white mb-2">Tech Documentation</h3>
                    <p class="text-sm text-gray-400">Clear reporting and documentation using Office suite.</p>
                </Card>
            </div>
        </section>

        <section id="technologies">
            <h2 class="text-3xl font-bold text-white mb-8 border-b border-white/10 pb-4">Technologies</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <Card title="Current Stack">
                    <div class="flex flex-wrap gap-4 mt-4">
                        {currentTechs.map(t => (
                            <span class="flex items-center gap-2 px-4 py-2 bg-blue-900/30 border border-blue-500/30 rounded-full text-blue-200 text-sm shadow-[0_0_10px_rgba(59,130,246,0.1)]">
                                <img src={t.icon} alt={t.name} class="w-5 h-5 object-contain" />
                                {t.name}
                            </span>
                        ))}
                    </div>
                </Card>
                <Card title="Learning Path">
                    <div class="flex flex-wrap gap-4 mt-4">
                        {learningTechs.map(t => (
                            <span class:list={[
                                "flex items-center gap-2 px-4 py-2 rounded-full text-sm",
                                t.name === "AWS Cloud" 
                                ? "bg-yellow-900/30 border border-yellow-500/50 text-yellow-300 shadow-[0_0_10px_rgba(245,158,11,0.2)]" 
                                : "bg-white/5 border border-white/10 text-gray-300"
                            ]}>
                                <img src={t.icon} alt={t.name} class="w-5 h-5 object-contain" />
                                {t.name === "AWS Cloud" ? `✨ ${t.name} ` : t.name}
                            </span>
                        ))}
                    </div>
                </Card>
            </div>
        </section>

        <Contact />

    </main>

    <script>
        import { initNetwork } from '../scripts/star.js';
        document.addEventListener('DOMContentLoaded', () => {
            initNetwork();
        });
    </script>
</body>
</html>